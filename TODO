
import "Something.mica" 
include "sys/epoll.h" 

record Entry a;                            // foward dec 

// type parameters without monomorphization bloat

record Entry a = {                        // parameters must hide behind ptrs
    values : [*a];                        // bounds checking on array deref
    offset : Int;
}

// sizeof(Entry a) is known! (36 bytes)
// offset = 4 bytes
// values = 24 bytes
// values.length = 8 bytes 

// tagged unions

variant Maybe : Kind -> Kind = {
    Just : *a -> Maybe a;
    Nothing : Maybe a;
}

// sizeof(Mayba a) ~ 12 (without padding)
// *a = 8 
// tag = 4

static f : (Int, Int) -> Int;             // normal declaration 
static f (x, y:Int) = x + y;              // function definition 
^               ^      
|               |----Type annotation is allowed 
|
|---- Specifiers must match in definition 

thread_local mutable fact : Int;
fact = 1;

foreign Event : Kind = struct epoll_event;
layout Event = { event : Int, data { ...etc... } };

// (a --> b) == 16 Byte Fat Pointer (Closure)
// (a *-> b) == 8 Byte Function Pointer


